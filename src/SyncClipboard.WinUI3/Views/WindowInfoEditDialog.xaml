<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog x:Class="SyncClipboard.WinUI3.Views.WindowInfoEditDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:local="using:SyncClipboard.WinUI3.Views"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:i18n="using:SyncClipboard.Core.I18n"
               Title="{x:Bind i18n:Strings.EditItem}"
               PrimaryButtonText="{x:Bind i18n:Strings.Confirm}"
               CloseButtonText="{x:Bind i18n:Strings.Cancel}"
               mc:Ignorable="d">
    <ContentDialog.Resources>
        <Style TargetType="local:WindowInfoEditDialog" BasedOn="{StaticResource DefaultContentDialogStyle}" />
    </ContentDialog.Resources>
    <StackPanel Spacing="12" MinWidth="400">
        <TextBox x:Name="_ProcessName"
                 Header="{x:Bind i18n:Strings.ProcessName}"
                 PlaceholderText="{x:Bind i18n:Strings.ProcessName}"
                 TextChanged="OnTextChanged" />
        <TextBox x:Name="_WindowTitle"
                 Header="{x:Bind i18n:Strings.WindowTitle}"
                 PlaceholderText="{x:Bind i18n:Strings.WindowTitle}"
                 TextChanged="OnTextChanged" />
        <TextBox x:Name="_ExecutableName"
                 Header="{x:Bind i18n:Strings.ExecutableName}"
                 PlaceholderText="{x:Bind i18n:Strings.ExecutableName}"
                 TextChanged="OnTextChanged" />
    </StackPanel>
</ContentDialog>
